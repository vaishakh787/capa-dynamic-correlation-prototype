{
  "rules": {
    "read file": {
      "matches": [
        {
          "features": [
            {"type": "api", "value": "CreateFileA"}
          ]
        }
      ]
    },
    "write file": {
      "matches": [
        {
          "features": [
            {"type": "api", "value": "WriteFile"}
          ]
        }
      ]
    },
    "network communication": {
      "matches": [
        {
          "features": [
            {"type": "api", "value": "connect"}
          ]
        }
      ]
    }
  }
}